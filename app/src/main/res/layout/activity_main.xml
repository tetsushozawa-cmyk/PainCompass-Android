<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="140dp"
    android:paddingEnd="24dp"
    android:paddingBottom="24dp">

    <ImageView
        android:id="@+id/topCompassThumbnail"
        android:layout_width="125dp"
        android:layout_height="125dp"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="16dp"
        android:contentDescription="@string/main_title"
        android:scaleType="centerCrop"
        android:src="@drawable/top_compass_thumbnail" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/main_title"
        android:textColor="@color/text_primary"
        android:textSize="32sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="@string/main_subtitle"
        android:textColor="@color/text_secondary"
        android:textSize="18sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/openRecordInputButton"
        android:layout_width="match_parent"
        android:layout_height="84dp"
        android:layout_marginTop="148dp"
        android:elevation="2dp"
        android:stateListAnimator="@null"
        android:text="@string/open_record_input"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="#108E71"
        app:cornerRadius="38dp"
        app:rippleColor="#22000000" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/openSavedRecordsButton"
        android:layout_width="match_parent"
        android:layout_height="84dp"
        android:layout_marginTop="64dp"
        android:elevation="2dp"
        android:stateListAnimator="@null"
        android:text="@string/open_saved_records"
        android:textAllCaps="false"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="#F8EDE3"
        app:cornerRadius="38dp"
        app:rippleColor="#18000000" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/openMandalaDataButton"
        android:layout_width="match_parent"
        android:layout_height="84dp"
        android:layout_marginTop="64dp"
        android:elevation="2dp"
        android:stateListAnimator="@null"
        android:text="@string/open_mandala_data"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="#1F4C8E"
        app:cornerRadius="38dp"
        app:rippleColor="#22000000" />
</LinearLayout>
