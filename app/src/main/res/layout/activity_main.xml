<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/main_title"
        android:textColor="@color/text_primary"
        android:textSize="28sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/openRecordInputButton"
        android:layout_width="match_parent"
        android:layout_height="84dp"
        android:layout_marginTop="36dp"
        android:backgroundTint="@color/accent"
        android:text="@string/open_record_input"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/openSavedRecordsButton"
        android:layout_width="match_parent"
        android:layout_height="84dp"
        android:layout_marginTop="64dp"
        android:backgroundTint="@color/clear_button"
        android:text="@string/open_saved_records"
        android:textAllCaps="false"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/openMandalaDataButton"
        android:layout_width="match_parent"
        android:layout_height="84dp"
        android:layout_marginTop="64dp"
        android:backgroundTint="@color/mandala_button"
        android:text="@string/open_mandala_data"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />
</LinearLayout>
