<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/mandala_data_title"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/mandalaPeriodText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/periodOneWeekButton"
                    android:layout_width="72dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:text="@string/period_one_week"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/periodTwoWeeksButton"
                    android:layout_width="72dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:text="@string/period_two_weeks"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/periodFourWeeksButton"
                    android:layout_width="72dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:text="@string/period_four_weeks"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/periodEightWeeksButton"
                    android:layout_width="72dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:text="@string/period_eight_weeks"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/periodTwelveWeeksButton"
                    android:layout_width="72dp"
                    android:layout_height="48dp"
                    android:text="@string/period_twelve_weeks"
                    android:textAllCaps="false" />
            </LinearLayout>
        </HorizontalScrollView>

        <TextView
            android:id="@+id/mandalaDataText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/saved_record_background"
            android:padding="16dp"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/mandala_map_title"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <com.example.painrecord001.MandalaMapView
                android:id="@+id/mandalaMapView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </HorizontalScrollView>

        <LinearLayout
            android:id="@+id/mandalaColorLegendLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/mandala_current_position_title"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/mandalaCurrentPositionLegendItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/mandala_color_legend_title"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/mandalaColorLegendItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical" />
        </LinearLayout>

        <Button
            android:id="@+id/mandalaReturnToTopButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:backgroundTint="@color/clear_button"
            android:text="@string/return_to_top"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
